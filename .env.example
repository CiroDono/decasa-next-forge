# =====================================================================
# VARIABLES DE ENTORNO — decasa-next-forge
# Copiá este archivo a .env y completá con tus valores reales.
# En Vercel: agregá cada variable en Project Settings > Environment Variables
# =====================================================================

# URL pública de la app (dominio de Vercel o dominio propio).
# IMPORTANTE: se usa para los redirect URLs de MercadoPago y el chatbot.
# Formato: https://tu-app.vercel.app  (sin barra final)
PUBLIC_BASE_URL="https://tu-app.vercel.app"

# Supabase — cliente browser (prefijo VITE_ para que Vite los exponga al frontend)
VITE_SUPABASE_URL="https://tu-proyecto.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="tu_anon_key"
VITE_SUPABASE_PROJECT_ID="tu_project_id"

# Supabase — servidor (sin prefijo VITE_, solo disponibles en el servidor)
SUPABASE_URL="https://tu-proyecto.supabase.co"
SUPABASE_PUBLISHABLE_KEY="tu_anon_key"
SUPABASE_SERVICE_ROLE_KEY="tu_service_role_key"

# Resend — emails transaccionales
# Verificá tu dominio en https://resend.com/domains antes de usar.
# El remitente DEBE ser de un dominio verificado en Resend.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Decasan <ventas@tudominio.com>"
ORDER_EMAIL_BCC="admin@tudominio.com"
ORDER_EMAIL_REPLY_TO="ventas@tudominio.com"

# MercadoPago — pagos
# Conseguilo en https://www.mercadopago.com.ar/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN="APP_USR_o_TEST_xxxxxxxxx"
MERCADOPAGO_WEBHOOK_SECRET="tu_webhook_secret"

# Chatbot Decabot — IA
# Opciones para obtener la clave:
#   - OpenAI: https://platform.openai.com/api-keys  (OpenAI API key)
#   - Google Gemini (gratuito): https://aistudio.google.com/apikey
# Si no configurás estas variables, el chatbot usa una respuesta de fallback
# sin IA y sigue funcionando (muestra info del catálogo sin respuesta inteligente).
LOVABLE_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# Andreani — calculador de envíos (opcional, si no usás Andreani podés dejarlo vacío)
ANDREANI_USERNAME="tu_usuario"
ANDREANI_PASSWORD="tu_password"
ANDREANI_CLIENT="tu_codigo_cliente"
ANDREANI_CONTRACT="tu_contrato"
ANDREANI_PRODUCT_CATEGORY="Herramientas y equipamiento"
ANDREANI_DESTINATION_CITY=""
ANDREANI_DEFAULT_DELIVERY_DAYS="5"
ANDREANI_LOGIN_URL="https://apis.andreani.com/login"
ANDREANI_QUOTE_URL="https://apis.andreanigloballpack.com/cotizador-globallpack/api/v1/Cotizador"
ANDREANI_BRANCHES_URL="https://apis.andreani.com/v2/sucursales"

# Configuración de envíos
SHIPPING_ORIGIN_CP="5172"
SHIPPING_ORIGIN_CITY="La Falda"
SHIPPING_DECLARED_VALUE="1000"
SHIPPING_DEFAULT_LENGTH_CM="20"
SHIPPING_DEFAULT_WIDTH_CM="20"
SHIPPING_DEFAULT_HEIGHT_CM="10"
SHIPPING_FALLBACK_BASE="500"
SHIPPING_FALLBACK_PER_KG="50"
